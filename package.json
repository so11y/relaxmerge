{
  "name": "relaxmerge",
  "version": "2.0.2",
  "description": "Config-driven selective deep merge: per-field strategies, glob field filtering, and custom merges.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "merge",
    "deep-merge",
    "deepmerge",
    "config",
    "object-merge",
    "strategy",
    "glob",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/so11y/relaxmerge.git"
  },
  "homepage": "https://github.com/so11y/relaxmerge#readme",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.4.0",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^3.2.6"
  }
}
